Testing The Model
import pandas as pd
# Define required time (clock)
required_time = 10
# New input (same feature format as training)
new_data = pd.DataFrame([{
"GateCount": 200,
"WireCount": 180,
"InputBits": 20,
"OutputBits": 10,
"AvgFanout": 2.7,
"MaxFanout": 8,
"LogicDepth": 15
}])
# Predict Delay
predicted_delay = model_delay.predict(new_data)[0]
# Compute Slack
predicted_slack = required_time - predicted_delay
# Predict Power
predicted_power = model_power.predict(new_data)[0]
# Output
print(f"Predicted Delay : {predicted_delay:.2f} ns")
print(f"Predicted Slack : {predicted_slack:.2f} ns")
print(f"Predicted Power : {predicted_power:.4f} units")
print(f"Timing Status : {'MET' if predicted_slack >= 0 else 'VIOLATED'}")
