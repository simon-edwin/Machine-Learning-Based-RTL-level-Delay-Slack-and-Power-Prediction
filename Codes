Codes used for YOSYS Synthesis
Flattening :-
yosys -p "
read_verilog $file.v;
hierarchy -check -top $file;
proc; opt;
fsm; opt;
memory; opt;
techmap; opt;
flatten; opt;
synth; opt;
write_json $file_flat_netlist.json;
write_verilog $file_flat_netlist.v

Making a tcl file:-
read_liberty sky130.lib
read_verilog $file.v
link_design $file
create_clock -name clk -period 10
set_input_delay 0 -clock clk [all_inputs]
set_output_delay 0 -clock clk [all_outputs]
report_checks -from [all_inputs] -to [all_outputs] -path_delay max

Making STA file :-
yosys -p "
read_verilog $file.v;
synth -top $file;
dfflibmap -liberty sky130.lib;
abc -liberty sky130.lib;
clean;
write_verilog $file_sta.v
exit
~/OpenSTA/build/sta sta_$file.tcl

